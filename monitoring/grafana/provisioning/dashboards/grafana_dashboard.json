{
  "title": "Insurance Cost API",
  "uid": "insurance-api",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Prediction rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "rate(predictions_total[1m])", "legendFormat": "v{{model_version}}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "title": "Total predictions served",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(predictions_total)", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "title": "Request latency p95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler))", "legendFormat": "{{handler}}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "title": "Requests by status code",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum(rate(http_requests_total[1m])) by (status)", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "title": "Predicted charge distribution (avg over time)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        { "expr": "rate(prediction_charge_sum[5m]) / rate(prediction_charge_count[5m])", "legendFormat": "avg predicted charge", "refId": "A" }
      ]
    }
  ]
}
